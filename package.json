{
  "name": "home",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "// --- Hardware (Metro ESP32-S3) ---": "",
    "hw:list": "arduino-cli board list",
    "hw:compile": "pio run -d hardware/plant-node",
    "hw:upload": "node scripts/flash.js --project plant-node --fqbn esp32:esp32:adafruit_metro_esp32s3 --target upload",
    "hw:flash": "node scripts/device_flash.js --project plant-node --fqbn esp32:esp32:adafruit_metro_esp32s3 --model \"Adafruit Metro ESP32-S3\"",
    "hw:monitor": "node scripts/flash.js --project plant-node --fqbn esp32:esp32:adafruit_metro_esp32s3 --target monitor",
    "// --- Hardware (ESP32-C3 Super Mini) ---": "",
    "env:compile": "pio run -d hardware/environment-sensor",
    "env:upload": "node scripts/flash.js --project environment-sensor --fqbn esp32:esp32:nologo_esp32c3_super_mini --target upload",
    "env:flash": "node scripts/device_flash.js --project environment-sensor --fqbn esp32:esp32:nologo_esp32c3_super_mini --model \"Nologo ESP32-C3 Super Mini\"",
    "env:monitor": "node scripts/flash.js --project environment-sensor --fqbn esp32:esp32:nologo_esp32c3_super_mini --target monitor",
    "// --- Hardware (RGB Display ESP32-S3) ---": "",
    "display:upload": "node scripts/flash.js --project rgb-display --fqbn esp32:esp32:esp32s3 --target upload",
    "display:flash": "node scripts/device_flash.js --project rgb-display --fqbn esp32:esp32:esp32s3 --model \"RGB Display ESP32-S3\"",
    "display:monitor": "node scripts/flash.js --project rgb-display --fqbn esp32:esp32:esp32s3 --target monitor",
    "// --- Infrastructure (Docker Compose) ---": "",
    "services:flash": "./scripts/check_disk.sh && npm run down && npm run up",
    "up": "docker compose --profile gpu up -d --build",
    "down": "docker compose --profile gpu down",
    "stop": "docker compose --profile gpu stop",
    "logs": "docker compose logs -f",
    "logs:mqtt": "docker compose logs -f mqtt-broker",
    "restart:api": "docker compose restart api",
    "api:dev": "docker compose exec api npm run dev",
    "// --- Database ---": "",
    "db:shell": "docker compose exec -it db psql -U user -d plants",
    "db:migrate": "docker compose exec api npm run migrate",
    "migrate": "node server/dist/database/migrate.js",
    "db:studio": "npx prisma studio",
    "gen:hw-config": "node scripts/gen_hardware_config.js",
    "// --- Python Venv ---": "",
    "py:setup": "python3 -m venv .venv && .venv/bin/pip install -r robot-vision-publisher/requirements.txt -r robot-vision-worker/requirements.txt",
    "py:shell": "bash -c 'source .venv/bin/activate && exec bash'",
    "vision:learn": ".venv/bin/python robot-vision-publisher/learn_face.py --broker 100.122.11.16 --port 1883",
    "vision:enroll": "bash scripts/enroll_face.sh",
    "vision:publish": ".venv/bin/python robot-vision-publisher/publisher.py --broker 100.122.11.16 --port 1883 --show-results",
    "// --- API Build ---": "",
    "build": "tsc",
    "dev": "ts-node --project tsconfig.json server/api/index.ts",
    "// --- Quality & Formatting ---": "",
    "lint": "clang-format --dry-run --Werror hardware/*/src/*.cpp hardware/*/src/*.h && eslint .",
    "format": "clang-format -i hardware/*/src/*.cpp hardware/*/src/*.h && eslint . --fix",
    "clean": "docker system prune -f"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.0",
    "@types/pg": "^8.11.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-html": "^8.1.4",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.3",
    "prettier-eslint": "^16.4.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "express": "^5.2.1",
    "kysely": "^0.29.2",
    "mqtt": "^5.15.1",
    "multer": "^2.1.1",
    "pg": "8.20.0",
    "systeminformation": "^5.31.5"
  }
}
