# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=plants
DATABASE_URL=postgres://user:changeme@db:5432/plants

# ── Internal service URLs (used by the API container) ─────────────────────────
MQTT_BROKER_URL=mqtt://mqtt-broker:1883
OLLAMA_URL=http://ollama:11434/api/chat

# ── App config ────────────────────────────────────────────────────────────────
PORT=5000
UPLOAD_PATH=/app/secure-private-storage/family
MEDIA_URL_PREFIX=/api/media             # URL prefix for private media files
ZIP_CODE=YOUR_ZIP_CODE                  # used for outdoor weather on the display
API_LOG_MAX_ROWS=50000                  # max rows retained in api_logs; oldest are pruned on each request
LOCATION_LABEL=Brooklyn, NY             # display label for the weather widget
AI_PLACEHOLDER=RTX 2070 Online. How can I help?  # fallback text when AI summary is unavailable

# ── Display board token ───────────────────────────────────────────────────────
# Must match DISPLAY_TOKEN in apps/hardware/lib/shared/config.h
# Generate with: openssl rand -hex 24
DISPLAY_TOKEN=generate_with_openssl_rand_hex_24

# ── Cloudflare Access (optional — remove if not using CF Access) ──────────────
CLOUDFLARE_TEAM_NAME=your_cloudflare_team_name

# ── Google OAuth (optional — remove if not using Google auth) ─────────────────
GCP_CLIENT_ID=your_google_oauth_client_id
GCP_CLIENT_SECRET=your_google_oauth_client_secret

HOMEASSISTANT_URL=http://your_domain:your_port
HOMEASSISTANT_TOKEN=your_home_assistant_long_lived_token

CALENDAR_ICS_URL=your_secret_ical_address