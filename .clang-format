---
Language: Cpp
BasedOnStyle: Google

# Match the 2-space indent common in JS/TS projects
IndentWidth: 2
ColumnLimit: 100

# Keep braces on the same line (Prettier-style)
BreakBeforeBraces: Attach

# Allow short functions and loops on one line if you prefer brevity
AllowShortFunctionsOnASingleLine: Empty
AllowShortBlocksOnASingleLine: false
AllowShortIfStatementsOnASingleLine: false

# Visual tweaks for readability
AlignAfterOpenBracket: Align
AlignOperands: true
SpaceAfterCStyleCast: true
SpaceBeforeParens: ControlStatements

# Ensure includes are sorted alphabetically
SortIncludes: true
---
